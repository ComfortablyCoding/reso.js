{
  "compilerOptions": {
    "outDir": "dist",
    "target": "esnext",
    "lib": ["es2023", "DOM"],
    "moduleDetection": "force",
    "module": "preserve",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "strict": true,
    "noUnusedLocals": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "isolatedDeclarations": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "paths": {
      "*": ["./*"],
      "@/*": ["./src/*"]
    }
  },

  "include": ["src"]
}
