{
  "$schema": "https://json.schemastore.org/package",
  "name": "reso.js",
  "version": "0.2.1",
  "description": "A robust, Typescript-first Node.js client designed for interacting with RESO Web API services, fully aligned with the current RESO Web API specification.",
  "keywords": [
    "data feed",
    "listings",
    "mls",
    "odata",
    "property",
    "real estate",
    "reso",
    "search",
    "web api",
    "webapi"
  ],
  "homepage": "https://github.com/ComfortablyCoding/reso.js#readme",
  "bugs": {
    "url": "https://github.com/ComfortablyCoding/reso.js/issues"
  },
  "license": "MIT",
  "author": {
    "name": "ComfortablyCoding",
    "url": "https://github.com/ComfortablyCoding"
  },
  "maintainers": [
    {
      "name": "ComfortablyCoding",
      "url": "https://github.com/ComfortablyCoding"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ComfortablyCoding/reso.js.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./middleware": "./dist/middleware/index.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "vitest",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint --fix",
    "lint:check": "oxlint"
  },
  "devDependencies": {
    "@typescript/native-preview": "7.0.0-dev.20260318.1",
    "oxfmt": "0.41.0",
    "oxlint": "1.56.0",
    "tsdown": "0.21.4",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  },
  "peerDependenciesMeta": {
    "p-ratelimit": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "p-ratelimit": "1.0.1"
  }
}
